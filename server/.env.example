# --- Environment selector ---
NOOZHA_ENV=development

# --- Database ---
# Async URL (asyncpg). For local dev with the docker-compose Postgres:
DATABASE_URL=postgresql+asyncpg://noozha:noozha@localhost:5432/noozha

# --- JWT auth ---
JWT_SECRET_KEY=change-me-to-at-least-32-random-characters-xxxxxxxxxx
ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# --- CORS ---
# Comma-separated. Production should pin to https://noozha.fr only.
CORS_ORIGINS=http://localhost:5173,http://localhost:8000

# --- Seed (used by scripts/seed.py only, NEVER read at runtime) ---
SEED_ADMIN_EMAIL=souhib.t@hotmail.fr
SEED_ADMIN_PASSWORD=change-me-after-first-login

# --- Misc ---
ENVIRONMENT=development
LOG_LEVEL=INFO
ENABLE_API_DOCS=true
